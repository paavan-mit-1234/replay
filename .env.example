# Database (async driver). Point at Supabase or a local Postgres.
REPLAY_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/replay

# Provider key vault. Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
REPLAY_VAULT_KEY=
# Optional comma separated old keys for rotation (decrypt only).
REPLAY_VAULT_KEYS_OLD=

# Supabase auth (leave blank to disable JWT verification in local dev).
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUD=authenticated

# Proxy limits and timeouts.
REPLAY_MAX_BODY_BYTES=2097152
REPLAY_UPSTREAM_CONNECT_TIMEOUT=10
REPLAY_UPSTREAM_READ_TIMEOUT=600

# Retention.
REPLAY_RETENTION_DAYS=30

# Logging.
REPLAY_LOG_LEVEL=INFO

# CLI target (used by the replay CLI to reach the API).
REPLAY_API_URL=http://localhost:8000
